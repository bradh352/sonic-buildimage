 cffi/source.c                                 | 257 ++++++++++++++++++
 libyang/context.py                            |  36 +++
 tests/test_schema.py                          |  67 +++++
 .../yang/yolo/yolo-leafref-search-extmod.yang |  39 +++
 tests/yang/yolo/yolo-leafref-search.yang      |  36 +++
 6 files changed, 441 insertions(+)
